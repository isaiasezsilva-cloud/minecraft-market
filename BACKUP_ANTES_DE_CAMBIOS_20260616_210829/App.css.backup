/* Variables temáticas Minecraft */
:root {
  --mc-dirt: #3a2a1a;
  --mc-grass: #4a7c2c;
  --mc-stone: #6b6b6b;
  --mc-wood: #5c3a21;
  --mc-diamond: #00ffff;
  --mc-emerald: #00aa00;
  --mc-gold: #ffaa00;
  --mc-iron: #d4a574;
  --mc-obsidian: #1a1a2e;
  --mc-sand: #c2b280;
  --mc-text: #ffffff;
  --mc-text-dark: #1a1a1a;
  --mc-border: #3d3d3d;
  --mc-panel: #c6c6c6;
  --mc-panel-dark: #8b8b8b;
}

* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

body {
  font-family: 'Minecraft', 'Press Start 2P', 'Courier New', monospace;
  background: linear-gradient(180deg, #1a1a2e 0%, #2d2d44 100%);
  min-height: 100vh;
  color: var(--mc-text);
}

#root {
  width: 100% !important;
  max-width: 100% !important;
  border: none !important;
}

.minecraft-market {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* Header */
.header {
  background: linear-gradient(135deg, var(--mc-dirt) 0%, var(--mc-stone) 100%);
  border-bottom: 4px solid var(--mc-grass);
  padding: 20px;
  text-align: center;
  box-shadow: 0 4px 8px rgba(0,0,0,0.5);
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 15px;
}

.header-content {
  max-width: 900px;
  margin: 0 auto;
}

.titulo {
  font-size: 2.5rem;
  color: var(--mc-diamond);
  text-shadow: 3px 3px 0px #000, -1px -1px 0 #000;
  letter-spacing: 2px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 15px;
  font-family: 'Minecraft', 'Press Start 2P', 'Courier New', monospace;
  font-weight: bold;
}

.titulo-icon {
  font-size: 2rem;
  animation: bounce 1s infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-5px); }
}

.subtitle {
  color: var(--mc-sand);
  font-size: 1rem;
  margin-top: 10px;
  text-shadow: 2px 2px 0 #000;
  font-family: 'Press Start 2P', 'Courier New', monospace;
  font-size: 0.7rem;
}

/* Botón de Carrito estilo Minecraft */
.btn-carrito-header {
  background: linear-gradient(135deg, var(--mc-emerald) 0%, #008800 100%);
  border: 4px solid #000;
  padding: 12px 20px;
  display: flex;
  align-items: center;
  gap: 10px;
  cursor: pointer;
  box-shadow: 
    inset -4px -4px 0 rgba(0,0,0,0.5),
    inset 4px 4px 0 rgba(255,255,255,0.3),
    4px 4px 0 #000;
  transition: transform 0.1s, box-shadow 0.1s;
  font-family: inherit;
  font-size: 1rem;
  color: #fff;
  text-shadow: 2px 2px 0 #000;
  position: relative;
  margin-top: 10px;
}

.btn-carrito-header:active {
  transform: translate(2px, 2px);
  box-shadow: 
    inset -2px -2px 0 rgba(0,0,0,0.5),
    inset 2px 2px 0 rgba(255,255,255,0.3),
    2px 2px 0 #000;
}

.carrito-icon {
  font-size: 1.5rem;
  animation: bounce 2s infinite;
}

.carrito-text {
  font-weight: bold;
}

.carrito-count {
  background: var(--mc-diamond);
  color: #000;
  padding: 4px 10px;
  border-radius: 4px;
  font-weight: bold;
  border: 2px solid #000;
  font-size: 0.9rem;
}

/* Carrito Modal */
.carrito-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 20px;
  overflow-y: auto;
}

.carrito-modal {
  background: linear-gradient(135deg, var(--mc-panel) 0%, var(--mc-panel-dark) 100%);
  border: 4px solid #000;
  border-radius: 8px;
  padding: 25px;
  max-width: 600px;
  width: 90%;
  max-height: 80vh;
  overflow-y: auto;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
  position: relative;
}

.carrito-modal h2 {
  color: var(--mc-text-dark);
  margin-bottom: 20px;
  text-align: center;
}

.btn-cerrar {
  position: absolute;
  top: 10px;
  right: 15px;
  background: var(--mc-stone);
  color: #fff;
  border: 3px solid #000;
  width: 35px;
  height: 35px;
  font-size: 1.5rem;
  cursor: pointer;
  border-radius: 4px;
  line-height: 1;
  box-shadow: inset -2px -2px 0 rgba(0,0,0,0.5), inset 2px 2px 0 rgba(255,255,255,0.3);
}

.btn-cerrar:hover {
  background: #ff4444;
}

.carrito-vacio {
  text-align: center;
  color: var(--mc-text-dark);
  padding: 40px;
  font-size: 1.2rem;
}

.carrito-items {
  display: flex;
  flex-direction: column;
  gap: 15px;
  margin-bottom: 20px;
}

.carrito-item {
  display: flex;
  align-items: center;
  gap: 15px;
  background: rgba(255, 255, 255, 0.5);
  padding: 15px;
  border-radius: 4px;
  border: 2px solid var(--mc-wood);
}

.carrito-item img {
  width: 80px;
  height: 80px;
  object-fit: contain;
  image-rendering: pixelated;
}

.carrito-info {
  flex: 1;
}

.carrito-info h4 {
  color: var(--mc-text-dark);
  margin: 0 0 5px 0;
  font-size: 1rem;
}

.carrito-info p {
  color: var(--mc-emerald);
  font-weight: bold;
  margin: 0;
}

.carrito-controles {
  display: flex;
  align-items: center;
  gap: 10px;
}

.carrito-controles button {
  background: var(--mc-stone);
  color: #fff;
  border: 2px solid #000;
  width: 30px;
  height: 30px;
  font-size: 1.2rem;
  cursor: pointer;
  border-radius: 4px;
}

.carrito-controles button:hover {
  background: var(--mc-dirt);
}

.carrito-controles span {
  min-width: 30px;
  text-align: center;
  font-weight: bold;
  color: var(--mc-text-dark);
}

.btn-remover {
  background: transparent;
  border: none;
  cursor: pointer;
  font-size: 1.5rem;
  padding: 5px;
}

.btn-remover:hover {
  transform: scale(1.2);
}

.calculadora-envio {
  margin: 20px 0;
}

.btn-calculadora {
  width: 100%;
  background: var(--mc-wood);
  color: #fff;
  border: 3px solid #000;
  padding: 12px;
  font-family: inherit;
  cursor: pointer;
  border-radius: 4px;
  font-size: 1rem;
  box-shadow: inset -3px -3px 0 rgba(0,0,0,0.5), inset 3px 3px 0 rgba(255,255,255,0.2);
}

.btn-calculadora:hover {
  background: var(--mc-dirt);
}

.calculadora-contenido {
  background: rgba(0, 0, 0, 0.3);
  padding: 15px;
  border-radius: 4px;
  margin-top: 10px;
  border: 2px solid var(--mc-stone);
}

.calculadora-contenido label {
  display: flex;
  flex-direction: column;
  gap: 10px;
  color: var(--mc-text);
  font-weight: bold;
}

.calculadora-contenido input {
  background: var(--mc-panel);
  border: 3px solid #000;
  padding: 10px;
  font-family: inherit;
  font-size: 1rem;
  border-radius: 4px;
  color: var(--mc-text-dark);
}

.formula-info {
  color: var(--mc-sand);
  margin-top: 10px;
  font-size: 0.9rem;
}

.formula-info code {
  background: var(--mc-obsidian);
  padding: 2px 8px;
  border-radius: 3px;
  color: var(--mc-diamond);
}

.carrito-totales {
  background: rgba(0, 0, 0, 0.3);
  padding: 15px;
  border-radius: 4px;
  border: 2px solid var(--mc-emerald);
  margin-bottom: 20px;
}

.total-row {
  display: flex;
  justify-content: space-between;
  padding: 8px 0;
  color: var(--mc-text);
  border-bottom: 1px dashed rgba(255, 255, 255, 0.2);
}

.total-row:last-child {
  border-bottom: none;
}

.total-row.total-final {
  font-size: 1.3rem;
  font-weight: bold;
  color: var(--mc-diamond);
  border-top: 2px solid var(--mc-emerald);
  margin-top: 10px;
  padding-top: 15px;
}

.btn-checkout {
  width: 100%;
  background: linear-gradient(135deg, var(--mc-emerald) 0%, #008800 100%);
  color: #fff;
  border: 4px solid #000;
  padding: 15px;
  font-family: inherit;
  font-size: 1.1rem;
  font-weight: bold;
  cursor: pointer;
  border-radius: 4px;
  box-shadow: inset -4px -4px 0 rgba(0,0,0,0.5), inset 4px 4px 0 rgba(255,255,255,0.2), 4px 4px 0 #000;
  transition: transform 0.1s, box-shadow 0.1s;
}

.btn-checkout:hover {
  background: linear-gradient(135deg, #00cc00 0%, var(--mc-emerald) 100%);
}

.btn-checkout:active {
  transform: translate(2px, 2px);
  box-shadow: inset -2px -2px 0 rgba(0,0,0,0.5), inset 2px 2px 0 rgba(255,255,255,0.2), 2px 2px 0 #000;
}

/* Filtros */
.filtros {
  background: var(--mc-wood);
  padding: 15px;
  display: flex;
  justify-content: center;
  gap: 10px;
  flex-wrap: wrap;
  border-bottom: 3px solid var(--mc-dirt);
}

.filtros button {
  background: var(--mc-panel);
  color: var(--mc-text-dark);
  border: 3px solid #000;
  padding: 10px 20px;
  font-family: 'Press Start 2P', 'Courier New', monospace;
  font-size: 0.7rem;
  cursor: pointer;
  box-shadow: inset -3px -3px 0 rgba(0,0,0,0.3), inset 3px 3px 0 rgba(255,255,255,0.3);
  transition: transform 0.1s;
}

.filtros button:active {
  transform: scale(0.95);
}

.filtros button.activo {
  background: var(--mc-emerald);
  color: #fff;
  box-shadow: inset -3px -3px 0 rgba(0,0,0,0.5), inset 3px 3px 0 rgba(255,255,255,0.2);
}

/* Contenido */
.contenido {
  flex: 1;
  padding: 20px;
  max-width: 1200px;
  margin: 0 auto;
  width: 100%;
}

/* Grid de Productos */
.grid-productos {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
  gap: 25px;
}

/* Card de Producto */
.producto-card {
  background: linear-gradient(135deg, var(--mc-panel) 0%, var(--mc-panel-dark) 100%);
  border: 4px solid #000;
  border-radius: 8px;
  overflow: hidden;
  box-shadow: 0 8px 16px rgba(0,0,0,0.4);
  transition: transform 0.2s;
  display: flex;
  flex-direction: column;
}

.producto-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 12px 24px rgba(0,0,0,0.5);
}

.producto-header {
  background: var(--mc-grass);
  padding: 10px 15px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 3px solid #000;
}

.categoria-badge {
  background: var(--mc-wood);
  color: #fff;
  padding: 4px 10px;
  border-radius: 4px;
  font-size: 0.8rem;
  text-transform: uppercase;
  border: 2px solid #000;
}

.clave-info {
  background: var(--mc-diamond);
  color: #000;
  padding: 4px 10px;
  border-radius: 4px;
  font-size: 0.75rem;
  font-weight: bold;
  border: 2px solid #000;
}

.producto-imagen {
  background: #fff;
  padding: 20px;
  display: flex;
  justify-content: center;
  align-items: center;
  border-bottom: 3px solid #000;
  min-height: 200px;
}

.producto-imagen img {
  max-width: 180px;
  max-height: 180px;
  image-rendering: pixelated;
}

.producto-info {
  padding: 15px;
  color: var(--mc-text-dark);
  flex: 1;
  display: flex;
  flex-direction: column;
}

.producto-nombre {
  color: var(--mc-dirt);
  font-size: 1.1rem;
  margin-bottom: 10px;
  text-shadow: 1px 1px 0 rgba(255,255,255,0.5);
  font-family: 'Press Start 2P', 'Courier New', monospace;
  font-weight: bold;
}

.producto-descripcion {
  font-size: 0.9rem;
  line-height: 1.4;
  margin-bottom: 15px;
  color: #333;
}

.producto-detalles {
  background: rgba(0,0,0,0.1);
  padding: 10px;
  border-radius: 4px;
  margin-bottom: 15px;
}

.detalle {
  display: flex;
  justify-content: space-between;
  padding: 5px 0;
  border-bottom: 1px dashed rgba(0,0,0,0.2);
}

.detalle:last-child {
  border-bottom: none;
}

.etiqueta {
  font-weight: bold;
  color: var(--mc-wood);
}

.valor {
  color: var(--mc-text-dark);
}

/* Calificación */
.calificacion {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px;
  background: rgba(0, 170, 0, 0.1);
  border-radius: 4px;
  border: 2px solid var(--mc-emerald);
}

.calificacion .etiqueta {
  color: var(--mc-emerald);
}

.diamantes {
  display: flex;
  gap: 3px;
}

.diamante {
  font-size: 1.2rem;
  filter: grayscale(100%);
  opacity: 0.5;
}

.diamante.lleno {
  filter: none;
  opacity: 1;
  animation: sparkle 2s infinite;
}

@keyframes sparkle {
  0%, 100% { filter: drop-shadow(0 0 2px var(--mc-diamond)); }
  50% { filter: drop-shadow(0 0 8px var(--mc-diamond)); }
}

.calificacion-numero {
  color: var(--mc-emerald);
  font-weight: bold;
}

/* Botón Agregar al Carrito */
.btn-agregar-carrito {
  width: 100%;
  background: linear-gradient(135deg, var(--mc-emerald) 0%, #008800 100%);
  color: #fff;
  border: 4px solid #000;
  padding: 12px;
  font-family: 'Press Start 2P', 'Courier New', monospace;
  font-size: 0.7rem;
  font-weight: bold;
  cursor: pointer;
  border-radius: 4px;
  box-shadow: inset -4px -4px 0 rgba(0,0,0,0.5), inset 4px 4px 0 rgba(255,255,255,0.3), 4px 4px 0 #000;
  transition: transform 0.1s, box-shadow 0.1s;
  text-shadow: 2px 2px 0 #000;
  margin-top: 15px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}

.btn-agregar-carrito:hover {
  background: linear-gradient(135deg, #00cc00 0%, var(--mc-emerald) 100%);
  transform: translateY(-2px);
  box-shadow: inset -4px -4px 0 rgba(0,0,0,0.5), inset 4px 4px 0 rgba(255,255,255,0.3), 6px 6px 0 #000;
}

.btn-agregar-carrito:active {
  transform: translate(2px, 2px);
  box-shadow: inset -2px -2px 0 rgba(0,0,0,0.5), inset 2px 2px 0 rgba(255,255,255,0.3), 2px 2px 0 #000;
}

/* Reseñas */
.resenas-section {
  border-top: 3px solid #000;
  flex-shrink: 0;
}

.btn-resenas {
  width: 100%;
  background: var(--mc-stone);
  color: #fff;
  border: none;
  padding: 12px;
  font-family: inherit;
  cursor: pointer;
  transition: background 0.2s;
}

.btn-resenas:hover {
  background: var(--mc-dirt);
}

.resenas-list {
  padding: 15px;
  background: rgba(0,0,0,0.3);
  display: flex;
  flex-direction: column;
  gap: 15px;
  animation: slideDown 0.3s ease-out;
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.resena-card {
  background: var(--mc-panel);
  padding: 15px;
  border-radius: 4px;
  border: 2px solid var(--mc-wood);
}

.aldeano-header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 10px;
}

.aldeano-foto {
  width: 50px;
  height: 50px;
  border-radius: 4px;
  border: 2px solid #000;
  image-rendering: pixelated;
}

.aldeano-info {
  display: flex;
  flex-direction: column;
}

.aldeano-nombre {
  font-weight: bold;
  color: var(--mc-text-dark);
}

.aldeano-badge {
  font-size: 0.75rem;
  color: var(--mc-emerald);
}

.resena-comentario {
  font-style: italic;
  color: #333;
  line-height: 1.5;
}

/* Footer */
.footer {
  background: var(--mc-dirt);
  border-top: 4px solid var(--mc-grass);
  padding: 20px;
  text-align: center;
  margin-top: auto;
}

.footer p {
  margin: 5px 0;
  color: var(--mc-sand);
}

.footer-note {
  font-size: 0.85rem;
  color: var(--mc-stone);
}

.footer-note code {
  background: var(--mc-obsidian);
  padding: 2px 8px;
  border-radius: 3px;
  color: var(--mc-diamond);
}

/* Loading */
.cargando {
  text-align: center;
  padding: 60px 20px;
}

.loading-diamond {
  font-size: 4rem;
  animation: spin 2s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.cargando p {
  margin-top: 20px;
  color: var(--mc-sand);
}

/* Responsive */
@media (max-width: 768px) {
  .titulo {
    font-size: 1.5rem;
  }
  
  .header {
    padding: 15px 10px;
  }
  
  .btn-carrito-header {
    padding: 10px 15px;
    font-size: 0.9rem;
  }
  
  .carrito-text {
    display: none;
  }
  
  .carrito-icon {
    font-size: 1.8rem;
  }
  
  .filtros {
    flex-direction: column;
    align-items: stretch;
  }
  
  .filtros button {
    width: 100%;
  }
  
  .grid-productos {
    grid-template-columns: 1fr;
    padding: 10px;
  }
  
  .producto-header {
    flex-direction: column;
    gap: 8px;
    text-align: center;
  }
  
  /* Carrito modal responsive */
  .carrito-modal {
    width: 95% !important;
    max-width: 95% !important;
    padding: 15px !important;
  }
  
  .carrito-item {
    flex-direction: column;
    text-align: center;
    gap: 10px;
  }
  
  .carrito-item img {
    width: 60px !important;
    height: 60px !important;
  }
  
  .carrito-controles {
    justify-content: center;
  }
  
  .total-row {
    font-size: 0.9rem;
  }
}

@media (max-width: 480px) {
  .titulo {
    font-size: 1.2rem;
  }
  
  .titulo-icon {
    font-size: 1.2rem;
  }
  
  .subtitle {
    font-size: 0.8rem;
  }
  
  .btn-carrito-header {
    padding: 8px 12px;
  }
  
  .carrito-count {
    padding: 2px 6px;
    font-size: 0.8rem;
  }
}